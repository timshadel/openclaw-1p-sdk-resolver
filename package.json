{
  "name": "openclaw-1p-sdk-resolver",
  "version": "0.1.0",
  "description": "OpenClaw exec secrets provider backed by 1Password SDK",
  "type": "module",
  "private": false,
  "files": [
    "bin",
    "dist",
    "README.md",
    "package.json"
  ],
  "bin": {
    "openclaw-1p-sdk-resolver": "./bin/openclaw-1p-sdk-resolver"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=text --coverage.reporter=json-summary",
    "check:coverage": "node scripts/check-coverage-thresholds.mjs",
    "check:docs": "node scripts/check-readme-help-sync.mjs && node scripts/check-doc-comment-consistency.mjs",
    "check:governance": "node scripts/check-plan-adr-required.mjs",
    "ci:preflight": "pnpm build && pnpm test && pnpm test:coverage && pnpm check:coverage && pnpm check:docs && pnpm check:governance",
    "prepack": "pnpm build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@1password/sdk": "0.4.0"
  },
  "devDependencies": {
    "@types/node": "25.3.3",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "4.20.3",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
